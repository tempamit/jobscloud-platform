generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Notice the url line is gone!
}

model City {
  id      Int    @id @default(autoincrement())
  slug    String @unique // e.g., "bangalore", "remote"
  name    String // e.g., "Bangalore", "Remote"
  country String? // e.g., "India"
  
  jobs    Job[]
}

model TechStack {
  id       Int    @id @default(autoincrement())
  slug     String @unique // e.g., "python", "react"
  name     String // e.g., "Python", "React JS"
  category String? // e.g., "Backend", "Frontend"
  
  jobs     Job[]
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String?  // Kept for scraped jobs
  description String
  url         String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cityId      String
  city        City     @relation(fields: [cityId], references: [id])

  techStackId String
  techStack   TechStack @relation(fields: [techStackId], references: [id])

  // NEW: Link to registered employers (Optional for scraped jobs)
  employerId  String?
  employer    EmployerProfile? @relation(fields: [employerId], references: [id])
}

// --- NEW AUTH & USER MODELS ---

enum Role {
  SEEKER
  EMPLOYER
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          Role     @default(SEEKER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  employerProfile EmployerProfile?
  seekerProfile   SeekerProfile?
}

model EmployerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  website     String?
  logoUrl     String?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs        Job[]    // An employer can post many jobs
}

model SeekerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  fullName    String
  bio         String?
  
  // This JSON field will hold the data generated by our future AI Resume Builder!
  resumeData  Json?    
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

